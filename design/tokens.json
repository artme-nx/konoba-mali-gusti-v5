{
  "$schema": "https://design-tokens.org/schema.json",
  "primitive": {
    "color": {
      "ceramic": {
        "50": { "$value": "#FBF6EC", "$type": "color" },
        "100": { "$value": "#F4E9D4", "$type": "color" },
        "300": { "$value": "#E1CEA3", "$type": "color" },
        "500": { "$value": "#9C8B6C", "$type": "color" },
        "900": { "$value": "#2A2116", "$type": "color" }
      },
      "olive": {
        "500": { "$value": "#6E7A45", "$type": "color" },
        "700": { "$value": "#454E29", "$type": "color" },
        "900": { "$value": "#232712", "$type": "color" }
      },
      "paprika": {
        "500": { "$value": "#D9552B", "$type": "color" },
        "700": { "$value": "#9E3A1B", "$type": "color" },
        "900": { "$value": "#55190A", "$type": "color" }
      },
      "wine": {
        "400": { "$value": "#8C2F42", "$type": "color" }
      }
    },
    "font": {
      "display": { "$value": "var(--font-dm-serif), 'DM Serif Display', Georgia, serif", "$type": "fontFamily" },
      "sans": { "$value": "var(--font-manrope), 'Manrope', system-ui, sans-serif", "$type": "fontFamily" },
      "mono": { "$value": "var(--font-overpass-mono), 'Overpass Mono', monospace", "$type": "fontFamily" }
    },
    "motion": {
      "duration": {
        "micro": { "$value": "160ms", "$type": "duration" },
        "base": { "$value": "300ms", "$type": "duration" },
        "reveal": { "$value": "0.9s", "$type": "duration" },
        "plate": { "$value": "0.7s", "$type": "duration" }
      },
      "ease": {
        "out-expo": { "$value": "cubic-bezier(0.16, 1, 0.3, 1)", "$type": "cubicBezier" },
        "plate": { "$value": "cubic-bezier(0.34, 1.56, 0.64, 1)", "$type": "cubicBezier" }
      }
    },
    "tracking": {
      "display": { "$value": "0em", "$type": "dimension" },
      "label": { "$value": "0.18em", "$type": "dimension" }
    }
  },
  "semantic": {
    "background": { "$value": "{primitive.color.ceramic.50}", "$type": "color" },
    "foreground": { "$value": "{primitive.color.ceramic.900}", "$type": "color" },
    "card": { "$value": "{primitive.color.ceramic.100}", "$type": "color" },
    "card-foreground": { "$value": "{primitive.color.ceramic.900}", "$type": "color" },
    "popover": { "$value": "{primitive.color.ceramic.50}", "$type": "color" },
    "popover-foreground": { "$value": "{primitive.color.ceramic.900}", "$type": "color" },
    "primary": { "$value": "{primitive.color.ceramic.900}", "$type": "color" },
    "primary-foreground": { "$value": "{primitive.color.ceramic.50}", "$type": "color" },
    "secondary": { "$value": "{primitive.color.ceramic.100}", "$type": "color" },
    "secondary-foreground": { "$value": "{primitive.color.ceramic.900}", "$type": "color" },
    "muted": { "$value": "{primitive.color.ceramic.100}", "$type": "color" },
    "muted-foreground": { "$value": "{primitive.color.ceramic.500}", "$type": "color" },
    "accent": { "$value": "{primitive.color.ceramic.300}", "$type": "color" },
    "accent-foreground": { "$value": "{primitive.color.ceramic.900}", "$type": "color" },
    "destructive": { "$value": "{primitive.color.paprika.700}", "$type": "color" },
    "border": { "$value": "{primitive.color.ceramic.300}", "$type": "color" },
    "input": { "$value": "{primitive.color.ceramic.300}", "$type": "color" },
    "ring": { "$value": "{primitive.color.paprika.500}", "$type": "color" },
    "radius": { "$value": "1.1rem", "$type": "dimension" },
    "olive": { "$value": "{primitive.color.olive.500}", "$type": "color" },
    "olive-dim": { "$value": "{primitive.color.olive.900}", "$type": "color" },
    "paprika": { "$value": "{primitive.color.paprika.500}", "$type": "color" },
    "wine": { "$value": "{primitive.color.wine.400}", "$type": "color" },
    "surface-line": { "$value": "{primitive.color.ceramic.300}", "$type": "color" },
    "type-display": { "$value": "{primitive.font.display}", "$type": "fontFamily" },
    "type-body": { "$value": "{primitive.font.sans}", "$type": "fontFamily" },
    "type-label": { "$value": "{primitive.font.mono}", "$type": "fontFamily" },
    "ease-reveal": { "$value": "{primitive.motion.ease.out-expo}", "$type": "cubicBezier" },
    "ease-plate": { "$value": "{primitive.motion.ease.plate}", "$type": "cubicBezier" },
    "duration-micro": { "$value": "{primitive.motion.duration.micro}", "$type": "duration" },
    "duration-base": { "$value": "{primitive.motion.duration.base}", "$type": "duration" },
    "duration-reveal": { "$value": "{primitive.motion.duration.reveal}", "$type": "duration" },
    "duration-plate": { "$value": "{primitive.motion.duration.plate}", "$type": "duration" },
    "tracking-display": { "$value": "{primitive.tracking.display}", "$type": "dimension" },
    "tracking-label": { "$value": "{primitive.tracking.label}", "$type": "dimension" }
  },
  "component": {
    "hero": {
      "title-size": { "$value": "clamp(2.75rem, 7vw, 5.75rem)", "$type": "dimension" },
      "title-leading": { "$value": "1.04", "$type": "number" },
      "kicker-size": { "$value": "0.7rem", "$type": "dimension" }
    },
    "button": {
      "primary-bg": { "$value": "{primitive.color.ceramic.900}", "$type": "color" },
      "primary-fg": { "$value": "{primitive.color.ceramic.50}", "$type": "color" },
      "primary-hover-bg": { "$value": "{primitive.color.paprika.500}", "$type": "color" },
      "primary-hover-fg": { "$value": "{primitive.color.ceramic.50}", "$type": "color" },
      "ghost-border": { "$value": "{primitive.color.ceramic.300}", "$type": "color" },
      "ghost-hover-border": { "$value": "{primitive.color.olive.500}", "$type": "color" }
    },
    "plate": {
      "rim-color": { "$value": "{primitive.color.ceramic.50}", "$type": "color" },
      "shadow": {
        "$value": "0 24px 48px -20px rgba(42, 33, 22, 0.35)",
        "$type": "shadow"
      }
    }
  }
}
